const flsPageHasInsights = true;
function insightHover(e) {
	return;
    if (e.currentTarget.classList.contains('insights--item--leftie')) {
	scrollInsight(false);
	}
    if (e.currentTarget.classList.contains('insights--item--rightie')) {
	scrollInsight();
	}
}
function scrollInsights(e) {
    if (e.currentTarget.classList.contains('insights--control--disabled')) return;
    let el = document.querySelector('main .insights .insights--items');
    let cwid = parseInt(document.querySelector('main .insights .insights--items .insights--item').offsetWidth) + 24;
    let amount = 2;
    if (window.matchMedia("(min-width: 1240px)").matches) amount = 3;
    let items = +el.dataset.full - amount;
    let offset = +el.dataset.current;
    let dir = true;
    if (e.currentTarget.classList.contains('insights--control--prev')) dir = false;
    let target = 0;
    if (dir) {
	target = Math.max(offset - (cwid * amount), 0 - (items * cwid));
	document.querySelector('main .insights .insights--control--prev').classList.remove('insights--control--disabled');
	if (target == 0 - (items * cwid)) document.querySelector('main .insights .insights--control--next').classList.add('insights--control--disabled');
    } else {
	target = Math.min(offset + (cwid * amount), 0); 
	document.querySelector('main .insights .insights--control--next').classList.remove('insights--control--disabled');
	if (target == 0) document.querySelector('main .insights .insights--control--prev').classList.add('insights--control--disabled');
    }
    let timing = Math.abs(Math.round((target - offset) / (cwid * amount) * 1000));
    el.dataset.current = target;
    el.style.transition = 'transform ' + timing +'ms linear';
    el.style.transform = 'translate('+target+'px, 0)';
}
function scrollInsight(dir = true) {
    let el = document.querySelector('main .insights .insights--items');
    let cwid = parseInt(document.querySelector('main .insights .insights--items .insights--item').offsetWidth) + 24;
    let amount = 2;
    if (window.matchMedia("(min-width: 1240px)").matches) amount = 3;
    let items = +el.dataset.full - amount;
    let offset = +el.dataset.current;
    let target = 0;
    if (dir) {
	target = Math.max(offset - cwid, 0 - (items * cwid));
	document.querySelector('main .insights .insights--control--prev').classList.remove('insights--control--disabled');
	if (target == 0 - (items * cwid)) document.querySelector('main .insights .insights--control--next').classList.add('insights--control--disabled');
    } else {
	target = Math.min(offset + cwid, 0); 
	document.querySelector('main .insights .insights--control--next').classList.remove('insights--control--disabled');
	if (target == 0) document.querySelector('main .insights .insights--control--prev').classList.add('insights--control--disabled');
    }
    let timing = Math.abs(Math.round((target - offset) / cwid * 1000));
    el.dataset.current = target;
    el.style.transition = 'transform ' + timing +'ms linear';
    el.style.transform = 'translate('+target+'px, 0)';
}
function insightObserver() {
    let scObserver = new IntersectionObserver((entries, observer) => {
	for (let entry of entries) {
	    if (entry.boundingClientRect.x < 0) entry.target.classList.add('insights--item--leftie');
	    else entry.target.classList.remove('insights--item--leftie');
	    if (entry.boundingClientRect.x + entry.boundingClientRect.width > entry.rootBounds.width) entry.target.classList.add('insights--item--rightie');
	    else entry.target.classList.remove('insights--item--rightie');
	}
    },{threshold: [0,1]});
    for (let el of document.querySelectorAll('.insights .insights--item')) scObserver.observe(el);
}